{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.local/share/opencode-guides/files/AGENTS.md",
    "AGENTS.md"
  ],
  "lsp": {},
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_TOKEN}"
      }
    }
  },
  "permission": {
    "external_directory": {
      "~/.local/share/opencode-guides/**": "allow"
    },
    "read": {
      "~/.local/share/opencode-guides/**": "allow"
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    }
  }
}
