{
  "Markdoc callout": {
    "prefix": "mcallout",
    "body": [
      "{% callout type=\"${1|note,warning,success,danger|}\" title=\"${2:Title}\" %}",
      "${0:Callout content}",
      "{% /callout %}"
    ],
    "description": "Markdoc callout block"
  },
  "Markdoc callout note": {
    "prefix": "mnote",
    "body": [
      "{% callout type=\"note\" title=\"${1:Note}\" %}",
      "${0:Callout content}",
      "{% /callout %}"
    ],
    "description": "Markdoc note callout"
  },
  "Markdoc callout warning": {
    "prefix": "mwarning",
    "body": [
      "{% callout type=\"warning\" title=\"${1:Warning}\" %}",
      "${0:Callout content}",
      "{% /callout %}"
    ],
    "description": "Markdoc warning callout"
  },
  "Markdoc callout success": {
    "prefix": "msuccess",
    "body": [
      "{% callout type=\"success\" title=\"${1:Success}\" %}",
      "${0:Callout content}",
      "{% /callout %}"
    ],
    "description": "Markdoc success callout"
  },
  "Markdoc callout danger": {
    "prefix": "mdanger",
    "body": [
      "{% callout type=\"danger\" title=\"${1:Danger}\" %}",
      "${0:Callout content}",
      "{% /callout %}"
    ],
    "description": "Markdoc danger callout"
  },
  "Markdoc codefence": {
    "prefix": "mcodefence",
    "body": [
      "{% codefence language=\"${2:text}\" title=\"${3:Example}\" %}",
      "```${1:text}",
      "${0}",
      "```",
      "{% /codefence %}"
    ],
    "description": "Markdoc codefence block"
  },
  "Markdoc figure image": {
    "prefix": "mfigureimg",
    "body": [
      "{% figure kind=\"image\" src=\"${1:/images/example.png}\" alt=\"${2:Descriptive alt text}\" title=\"${3:Figure title}\" credit=\"${4:Credit}\" %}",
      "${0:Optional markdown caption}",
      "{% /figure %}"
    ],
    "description": "Markdoc figure tag for image"
  },
  "Markdoc figure video": {
    "prefix": "mfigurevid",
    "body": [
      "{% figure kind=\"video\" src=\"${1:/videos/example.mp4}\" poster=\"${2:/images/poster.png}\" title=\"${3:Figure title}\" credit=\"${4:Credit}\" %}",
      "${0:Optional markdown caption}",
      "{% /figure %}"
    ],
    "description": "Markdoc figure tag for video"
  },
  "Anki sidecar card": {
    "prefix": "ankicard",
    "body": [
      "{% ankicard %}",
      "",
      "md:",
      "",
      "${1}",
      "",
      "context:",
      "",
      "${2}",
      "",
      "{% /ankicard %}",
      "$0"
    ],
    "description": "Anki sidecar card block"
  },
  "Markdoc math inline": {
    "prefix": "mmath",
    "body": [
      "{% math %}${1:\\alpha}{% /math %}$0"
    ],
    "description": "Markdoc inline math tag"
  },
  "Markdoc math block": {
    "prefix": "mmathblock",
    "body": [
      "{% mathblock %}",
      "${1:\\text{expression}}",
      "{% /mathblock %}",
      "$0"
    ],
    "description": "Markdoc block math tag"
  },
  "Markdoc title placeholder": {
    "prefix": "mtitle",
    "body": [
      "{% title /%}$0"
    ],
    "description": "Markdoc title placeholder tag"
  },
  "Markdoc mermaid": {
    "prefix": "mmermaid",
    "body": [
      "{% mermaid %}",
      "${1:graph TD}",
      "${2:A[Start] --> B[End]}",
      "{% /mermaid %}",
      "$0"
    ],
    "description": "Markdoc mermaid diagram tag"
  }
}
